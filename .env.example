# ===========================================
# FCM (Firebase Cloud Messaging) - 복구 시 필수
# ===========================================
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 키 생성 후
# JSON의 project_id, client_email, private_key 를 아래에 맞게 넣으세요.
# private_key 는 한 줄로 넣고 줄바꿈은 \n 으로 두어도 됩니다 (코드에서 자동 치환).

FIREBASE_PROJECT_ID=gig-market-85c5e
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@gig-market-85c5e.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 위 세 변수가 없으면 푸시 알림이 비활성화됩니다.
# 권한 오류 시: scripts/verify-firebase-permissions.md 참고.

# ===========================================
# Xendit (결제)
# ===========================================
# Xendit 대시보드 → API Keys 에서 Secret Key 복사 (xnd_development_... 또는 xnd_production_...)
# 없으면 결제 요청 시 "Invalid secret key" 또는 500 발생.

XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxxxxxx
# XENDIT_WEBHOOK_VERIFY_TOKEN=  # 웹훅 사용 시 Xendit에서 설정한 callback token 과 동일하게

# ===========================================
# AWS S3 (provider-ads, projects 업로드 Presigned URL)
# ===========================================
# 버킷 이름만 입력 (ARN 아님). 없으면 /provider-ads/upload-url, /projects/upload-url 호출 시 500.
AWS_S3_BUCKET=gigmarket
AWS_REGION=ap-northeast-2
# IAM 액세스 키 (S3 PutObject 등 권한 필요). .env 에만 넣고 저장소에 커밋하지 마세요.
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
